# ============================================================
#  Configuración de despliegue — Gemelo Digital (Docker)
#  -----------------------------------------------------------
#  1. Copia este archivo a «.env»  →  cp .env.example .env
#  2. Ajusta los valores a tu servidor.
#  3. Construye y arranca         →  docker compose up --build -d
#
#  Docker Compose lee «.env» automáticamente desde esta carpeta.
# ============================================================

# --- Puertos del HOST (los que el servidor expone) ----------
#  Cambia SOLO estos números si los puertos por defecto están ocupados.
#  El puerto interno de cada contenedor es fijo y no se toca.
FRONTEND_PORT=3000      # Aplicación web (Next.js)
BACKEND_PORT=8000       # API (FastAPI + GraphQL)
CLIMA_PORT=8001         # Servidor de clima mock (opcional)
MONGO_PORT=27017        # Base de datos MongoDB

# --- Base de datos ------------------------------------------
MONGODB_DB=GemeloDigitalCujai

# --- Seguridad ----------------------------------------------
#  CÁMBIALO por una cadena larga y aleatoria en producción.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# --- URLs públicas (IMPORTANTE) -----------------------------
#  El NAVEGADOR del usuario debe poder alcanzar el backend con estas URLs.
#  Estas URLs se incrustan en el frontend al construir (--build),
#  así que defínelas ANTES de hacer «docker compose up --build».
#
#  · Si accedes desde la MISMA máquina:
#       NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql
#       NEXT_PUBLIC_API_URL=http://localhost:8000
#
#  · Si accedes desde la RED (IP o dominio del servidor):
#       NEXT_PUBLIC_GRAPHQL_URL=http://192.168.1.50:8000/graphql
#       NEXT_PUBLIC_API_URL=http://192.168.1.50:8000
#
#  Recuerda usar el MISMO número que pusiste en BACKEND_PORT.
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- CORS ---------------------------------------------------
#  Orígenes desde los que el frontend llama al backend.
#  Debe coincidir con la URL pública del FRONTEND (host + FRONTEND_PORT).
#  Separar varios orígenes por comas, sin espacios.
#    Ej. red:  http://192.168.1.50:3000
CORS_ORIGINS=http://localhost:3000
